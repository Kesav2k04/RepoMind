# Optional: enables four GPT-5.6 source specialists plus a separate root
# reconciliation call. Missing/slow/invalid provider work falls back visibly
# to deterministic Evidence Mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
REPOMIND_GPT_TIMEOUT_SECONDS=45

# Optional. Leave blank to use D:/dev-cache/repomind/repos when D: exists
# locally, otherwise a portable system-temp cache. Set any writable local path
# to override the default.
REPOMIND_CACHE_DIR=
REPOMIND_CLONE_TIMEOUT_SECONDS=120

# Browser origins allowed to call a separately deployed API (comma-separated).
# Local Vite origins are always included for development.
REPOMIND_CORS_ORIGINS=https://your-frontend.example

# Bound public analysis work on a single demo instance.
REPOMIND_MAX_CONCURRENT_JOBS=2
